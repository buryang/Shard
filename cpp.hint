#define ALIGN_AS(align) alignas(align)
#define OVERLOAD_OPERATOR_NEW(class_name) void* operator new(std::size_t size){ assert(size == sizeof(class_name)); return g_hal_allocator->Alloc(size); } void operator delete(void* ptr){ g_hal_allocator->DeAlloc(ptr, sizeof(class_name)); }
#define FORCE_INLINE
