prefix=D:/Exp/MetaInit/Externals/abseil
exec_prefix=${prefix}
libdir=D:/Exp/MetaInit/Externals/abseil/lib
includedir=D:/Exp/MetaInit/Externals/abseil/include

Name: absl_time
Description: Abseil time library
URL: https://abseil.io/
Version: head
Requires: absl_base = head, absl_civil_time = head, absl_core_headers = head, absl_int128 = head, absl_raw_logging_internal = head, absl_strings = head, absl_time_zone = head
Libs: -L${libdir}  -labsl_time
Cflags: -I${includedir} /W3 /DNOMINMAX /DWIN32_LEAN_AND_MEAN /D_CRT_SECURE_NO_WARNINGS /D_SCL_SECURE_NO_WARNINGS /D_ENABLE_EXTENDED_ALIGNED_STORAGE /bigobj /wd4005 /wd4068 /wd4180 /wd4244 /wd4267 /wd4503 /wd4800
